# Auto detect text files and perform LF normalization
* text=auto

# Source code
*.c text
*.h text
*.cpp text
*.hpp text
*.s text
*.S text

# Scripts
*.sh text eol=lf
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Documentation
*.md text
*.txt text
README text

# Configuration files
*.json text
*.xml text
*.yml text
*.yaml text
.gitignore text
.gitattributes text

# Linker scripts
*.ld text
*.lds text

# Makefiles
Makefile text
makefile text
*.mk text

# Binary files
*.bin binary
*.hex binary
*.elf binary
*.o binary
*.obj binary
*.a binary
*.lib binary
*.so binary
*.dll binary
*.exe binary
*.out binary

# Images
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.bmp binary

# Archives
*.zip binary
*.tar binary
*.gz binary
*.7z binary
*.rar binary
